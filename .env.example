# ============================================================
# REGALARTE — Variables de Entorno
# Copiar este archivo como .env.local y completar los valores
# NUNCA commitear .env.local al repositorio
# ============================================================

# ============================================================
# DATABASE — PostgreSQL
# ============================================================
DATABASE_URI=postgresql://regalarte_user:regalarte_pass@localhost:5432/regalarte_db

# ============================================================
# PAYLOAD CMS
# ============================================================
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=change-this-to-a-random-32-char-secret

# ============================================================
# CLOUDFLARE R2 (Storage)
# ============================================================
R2_ACCESS_KEY_ID=placeholder-r2-access-key
R2_SECRET_ACCESS_KEY=placeholder-r2-secret-key
R2_BUCKET=regalarte-media
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.regalarte.com

# ============================================================
# MERCADO PAGO (Pagos)
# ============================================================
MERCADOPAGO_ACCESS_TOKEN=placeholder-mp-access-token
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=placeholder-mp-public-key

# ============================================================
# RESEND (Email)
# ============================================================
RESEND_API_KEY=placeholder-resend-api-key
RESEND_FROM_EMAIL=noreply@regalarte.com
RESEND_FROM_NAME=REGALARTE

# ============================================================
# ANALYTICS
# ============================================================
NEXT_PUBLIC_POSTHOG_KEY=placeholder-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-PLACEHOLDER
# Microsoft Clarity — sin backend, solo script en layout

# ============================================================
# APP CONFIG
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=REGALARTE

# ============================================================
# WHOLESALE CONFIG (configurable desde CMS — aquí solo para dev inicial)
# ============================================================
# El valor real se gestiona desde Payload CMS > Globals > Commerce Settings
# MINIMUM_WHOLESALE_ORDER=150000
